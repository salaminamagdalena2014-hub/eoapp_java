<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>EoApp - Gestión de Gastos Personales</display-name>
    <description>GA7-220501096-AA2-EV02</description>

    <!-- Página de inicio -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- Servlet: GastoServlet -->
    <servlet>
        <servlet-name>GastoServlet</servlet-name>
        <servlet-class>com.eoapp.servlet.GastoServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>GastoServlet</servlet-name>
        <url-pattern>/gastos</url-pattern>
    </servlet-mapping>

    <!-- Servlet: IngresoServlet -->
    <servlet>
        <servlet-name>IngresoServlet</servlet-name>
        <servlet-class>com.eoapp.servlet.IngresoServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>IngresoServlet</servlet-name>
        <url-pattern>/ingresos</url-pattern>
    </servlet-mapping>

    <!-- Servlet: BalanceServlet -->
    <servlet>
        <servlet-name>BalanceServlet</servlet-name>
        <servlet-class>com.eoapp.servlet.BalanceServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>BalanceServlet</servlet-name>
        <url-pattern>/balance</url-pattern>
    </servlet-mapping>

    <!-- Configuración de sesión: 30 minutos -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <!-- Codificación UTF-8 para todos los request -->
    <filter>
        <filter-name>CharacterEncodingFilter</filter-name>
        <filter-class>org.apache.catalina.filters.SetCharacterEncodingFilter</filter-class>
        <init-param>
            <param-name>encoding</param-name>
            <param-value>UTF-8</param-value>
        </init-param>
    </filter>
    <filter-mapping>
        <filter-name>CharacterEncodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

</web-app>
